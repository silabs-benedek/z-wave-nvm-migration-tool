# Enforce LF line endings for text files
* text=auto

# Force LF for specific file types
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# Force LF for C source and header files
*.c text eol=lf
*.h text eol=lf

# Force LF for JSON files
*.json text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
