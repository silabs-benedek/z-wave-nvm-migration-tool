              "description": "true if the device is a FLiRS node.",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "isRouting": {
              "description": "true if the device is capable of repeating frames.",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "supportedDataRates": {
              "description": "list of data rates supported by the product.",
              "type": "array",
              "items": {
                "enum": [
                  100000
                ]
              },
              "group": "stack",
              "default_value": [
                100000
              ],
              "created": 0
            },
            "protocolVersion": {
              "description": "protocol version supported by the product.",
              "type": "integer",
              "group": "stack",
              "default_value": 1,
              "created": 0
            },
            "optionalFunctionality": {
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "nodeType": {
              "description": "node type, 0 for a controller, 1 for an end device",
              "type": "integer",
              "group": "stack",
              "default_value": 1,
              "created": 0
            },
            "supportsSecurity": {
              "description": "supports security",
              "type": "boolean",
              "group": "stack",
              "default_value": true,
              "created": 0
            },
            "supportsBeaming": {
              "description": "the device is able to send beam.",
              "type": "boolean",
              "group": "stack",
              "default_value": true,
              "created": 0
            },
            "genericDeviceClass": {
              "description": "generic device class",
              "type": "integer",
              "group": "stack",
              "default_value": 0,
              "created": 0
            },
            "specificDeviceClass": {
              "description": "specific device class",
              "$ref": "#/definitions/specificDeviceClassType",
              "group": "stack",
              "default_value": null,
              "created": 0
            },
            "lrTxpower": {
              "type": "integer",
              "minmum": 0,
              "maximum": 255,
              "default_value": 140,
              "created": 2,
              "removed": 4
            }
          },
          "required": [
            "isListening",
            "isRouting",
            "optionalFunctionality",
            "supportsSecurity",
            "supportsBeaming",
            "genericDeviceClass"
          ]
        }
      }
    },
    "unknown": {
      "description": "list of unknown keys in the original NVM file",
