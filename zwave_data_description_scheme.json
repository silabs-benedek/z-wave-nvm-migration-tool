{
  "title": "zwave_controller_nvm_data",
  "description": "Data store by a Z-Wave controller in its Non Volatile Memory",
  "comments": [
    "Data is divided into two groups: 'stack' and 'application', each with its own format.",
    "Data from the group 'stack' uses the format 'format'. Data from the group 'application' uses the format 'applicationFileFormat'",
    "The 'applicationFileFormat' has been introduced in version 7.24.0.",
    "So in case of 'applicationFileFormat' = 0, the format of the group 'application', should rely on 'controller.applicationVersion'.",
    "This schema lists data for all format. To check which data is available on a specific format, use the following attributes:",
    "'created' indicates the format in which the data is created. If missing, the data exists since the first format.",
    "'createdVersion' can be used instead of 'created' if the creation of the data does not match a change of format.",
    "'removed' indicates the format in which the data is removed. If missing, the data still exists.",
    "Data exists if the format is greater than or equal to 'data.created' and less than 'data.removed'.",
    "'default_value' is the value that should be set when the data is created.",
    "A data is mandatory only if it exists in the selected format, and if it is part of the required list.",
    "'zwavejs' attribute describe the difference with zwavejs scheme."
  ],
  "versionManagement": [
    "'version' is a semantic version of this file.",
    "'properties.format.version' or 'properties.applicationFileFormat.version' are the latest data version implemented in this file."
  ],
  "todo": [
    "add missing descriptions"
  ],
  "version": "0.00.11",
  "type": "object",
  "properties": {
    "format": {
      "description": "Format of stack's data",
      "type": "integer",
      "version": 5
    },
    "applicationFileFormat": {
      "description": "Format of application & zaf data",
      "type": "integer",
      "group": "stack",
      "version": 1
    },
    "controller": {
      "description": "Generic data stored by the Z-Wave stack, ZAF and the controller application.",
      "type": "object",
      "properties": {
        "protocolVersion": {
          "description": "The protocol version used by the controller",
          "type": "string",
          "subtype": "version",
          "pattern": "^[0-9]{1,2}.[0-9]{1,2}.[0-9]{1,2}$",
          "group": "stack",
          "created": 0
        },
        "applicationVersion": {
          "description": "The application version of the controller",
          "type": "string",
          "subtype": "version",
          "pattern": "^[0-9]{1,2}.[0-9]{1,2}.[0-9]{1,2}$",
          "group": "application",
          "created": 0
        },
        "applicationName": {
          "description": "Name of the application",
          "type": "string",
          "subtype": "string",
          "pattern": "^[.]{,30}$",
          "group": "application",
          "createdVersion": "7.20.0",
          "default_value": "serial_api_controller"
        },
        "homeId": {
          "description": "Home ID of the network (4 bytes in hexadecimal)",
          "type": "string",
          "subtype": "hexadecimal",
          "pattern": "^0x[0-9A-Fa-f]{8}$",
          "group": "stack",
          "default_value": "0x00000000",
          "created": 0
        },
        "nodeId": {
          "description": "Controller's nodeID in the network",
          "type": "integer",
          "minimum": 1,
          "maximum": 255,
          "group": "stack",
          "default_value": 1,
          "created": 0
        },
        "staticControllerNodeId": {
          "description": "NodeID of the static controller in the network",
          "type": "integer",
          "minimum": 1,
          "maximum": 255,
          "group": "stack",
          "default_value": 0,
          "created": 0
        },
        "lastNodeId": {
          "description": "Last NodeID assigned in the network",
          "type": "integer",
          "minimum": 1,
          "maximum": 255,
          "group": "stack",
          "default_value": 1,
          "created": 0
        },
        "lastNodeIdLR": {
          "description": "Last Long Range NodeID assigned in the network",
          "type": "integer",
          "minimum": 255,
          "maximum": 4096,
          "group": "stack",
          "default_value": 255,
          "created": 2
        },
        "sucLastIndex": {
          "description": "Index of last entry in the suc node list file, maximum value is 64",
          "type": "integer",
          "minimum": 0,
          "group": "stack",
          "default_value": 1,
          "created": 0
        },
        "controllerIsSecondary": {
          "description": "The controller is the secondary controller of the network",
          "type": "boolean",
          "group": "stack",
          "default_value": false,
          "zwavejs": "part of controllerConfiguration",
          "created": 0
        },
        "controllerOnOtherNetwork": {
          "description": "The controller is included in other network through replication and not using its built-in home ID",
          "type": "boolean",
          "group": "stack",
          "default_value": false,
          "zwavejs": "part of controllerConfiguration",
          "created": 0
        },
        "controllerNodeIdServerPresent": {
          "description": "Indicates that there is a SUC ID server (SIS) in the network and this controller can therefore include/exclude nodes in the network. This is called an inclusion controller",
          "type": "boolean",
          "group": "stack",
          "default_value": false,
          "zwavejs": "part of controllerConfiguration",
          "created": 0
        },
        "controllerIsRealPrimary": {
          "description": "The controller is the real primary of the network",
          "type": "boolean",
          "group": "stack",
          "default_value": true,
          "zwavejs": "part of controllerConfiguration",
          "created": 0
        },
        "controllerIsSuc": {
          "description": "The controller is SUC.",
          "type": "boolean",
          "group": "stack",
          "default_value": false,
          "zwavejs": "part of controllerConfiguration",
          "created": 0
        },
        "noNodesIncluded": {
          "description": "No classic node is included in the network",
          "type": "boolean",
          "group": "stack",
          "default_value": true,
          "zwavejs": "part of controllerConfiguration",
          "created": 0
        },
        "sucAwarenessPushNeeded": {
          "description": "SUC awareness push needed",
          "type": "null",
          "group": "stack",
          "default_value": null,
          "created": 0,
          "removed": 2
        },
        "maxNodeId": {
          "description": "The maximum node ID that has been assigned to a Z-Wave device in the classic network",
          "type": "integer",
          "group": "stack",
          "default_value": 1,
          "minimum": 0,
          "maximum": 255,
          "created": 0
        },
        "maxNodeIdLR": {
          "description": "The maximum node ID that has been assigned to a Z-Wave device in the LR network",
          "type": "integer",
          "group": "stack",
          "default_value": 0,
          "minimum": 0,
          "maximum": 4096,
          "created": 2
        },
        "reservedId": {
          "description": "Free Classic node IDs reserved for including new nodes",
          "type": "integer",
          "group": "stack",
          "default_value": 0,
          "created": 0
        },
        "reservedIdLR": {
          "description": "Free LR node IDs reserved for including new nodes",
          "type": "integer",
          "group": "stack",
          "default_value": 0,
          "created": 2
        },
        "systemState": {
          "description": "Learn mode system state, Idle or Smart Start. Used for determining if Local Reset needed on statup",
          "type": "integer",
          "group": "stack",
          "default_value": 0,
          "created": 0
        },
        "primaryLongRangeChannelId": {
          "description": "Primary channel to use in long range",
          "comment": [
            "Uninitialized: Long Range Channel setting is not initialized",
            "Channel A: Long Range Channel A",
            "Channel B: Long Range Channel B",
            "Unknown: Long Range Channel Unknown",
            "Auto: Long Range automatically selected channel"
          ],
          "type": "integer",
          "group": "stack",
          "default_value": 0,
          "zwavejs": "type is integer",
          "created": 2
        },
        "longRangeChannelAutoMode": {
          "description": "Primary channel to use in long range",
          "comment": [
            "false: Automode Disabled",
            "true: Automode Enabled, if channel selection is set to Auto"
          ],
          "type": "boolean",
          "group": "stack",
          "default_value": false,
          "createdVersion": "7.19.0"
        },
        "preferedRepeater": {
          "description": "List of prefered repeaters",
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "group": "stack",
          "created": 0,
          "removed": 2
        },
        "isListening": {
          "description": "Is the controller always listening",
          "type": "boolean",
          "group": "application",
          "default_value": true,
          "createdVersion": "7.11.0"
        },
        "genericDeviceClass": {
          "description": "Generic device type",
          "type": "integer",
          "group": "application",
          "default_value": 2,
          "createdVersion": "7.11.0"
        },
        "specificDeviceClass": {
          "description": "Specific device type",
          "$ref": "#/definitions/specificDeviceClassType",
          "group": "application",
          "default_value": null,
          "createdVersion": "7.11.0"
        },
        "cmdClasses": {
          "description": "list of command class supported by the controller",
          "type": "object",
          "properties": {
            "includedInsecurely": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "group": "application",
              "default_value": [],
              "createdVersion": "7.11.0"
            },
            "includedSecurelyInsecureCCs": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "default_value": [],
              "group": "application",
              "createdVersion": "7.11.0"
            },
            "includedSecurelySecureCCs": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "default_value": [],
              "group": "application",
              "createdVersion": "7.11.0"
            }
          },
          "required": [
            "includedInsecurely",
            "includedSecurelyInsecureCCs",
            "includedSecurelySecureCCs"
          ]
        },
        "rfConfig": {
          "type": "object",
          "properties": {
            "rfRegion": {
              "description": "Z-Wave region for frequency selection",
              "type": "integer",
              "group": "application",
              "default_value": 255,
              "createdVersion": "7.11.0"
            },
            "txPower": {
              "description": "Maximum tx power for Z-Wave classic",
              "type": "number",
              "group": "application",
              "default_value": 20.0,
              "createdVersion": "7.11.0"
            },
            "measured0dBm": {
              "description": "power level adjustment",
              "type": "number",
              "group": "application",
              "default_value": 0,
              "createdVersion": "7.11.0"
            },
            "enablePTI": {
              "description": "PTI radio debug enforce",
              "type": "boolean",
              "group": "application",
              "default_value": false,
              "createdVersion": "7.15.3"
            },
            "maxTxPower": {
              "description": "Maximum tx power for Z-Wave LR",
              "type": "number",
              "group": "application",
              "default_value": 0,
              "createdVersion": "7.15.3"
            },
            "nodeIdType": {
              "description": "Specifying if the SerialAPI command Node ID fields are 8 or 16 bits",
              "comment": [
                "1: 8 bits",
                "2: 16 bits"
              ],
              "type": "integer",
              "group": "application",
              "default_value": 1,
              "createdVersion": "7.21.0"
            }
          },
          "required": [
            "rfRegion",
            "txPower",
            "measured0dBm",
            "enablePTI",
            "maxTxPower",
            "nodeIdType"
          ]
        },
        "applicationData": {
          "description": "Data store by the HOST",
          "type": "string",
          "subtype": "hexadecimal",
          "pattern": "^[0-9A-Fa-f]{1024}$",
          "group": "application",
          "default_value": "",
          "createdVersion": "7.11.0"
        },
        "dcdcConfig": {
          "description": "Configuration of Silicon Labs dcdc power mode",
          "comment": [
            "0: Auto",
            "1: Bypass",
            "2: DCDC Low Noise"
          ],
          "type": "integer",
          "group": "application",
          "default_value": 0,
          "createdVersion": "7.18.0"
        },
        "sucUpdateEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nodeId": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255
              },
              "changeType": {
                "type": "integer",
                "minimum": 0,
                "maximum": 255,
                "created": 0,
                "default_value": 0
              },
              "supportedCCs": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "created": 0,
                "default_value": []
              },
              "controlledCCs": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "created": 0,
                "default_value": []
              }
            },
            "required": [
              "nodeID",
              "changeType",
              "supportedCCs",
              "controlledCCs"
            ]
          },
          "group": "stack",
          "version": "7.11.0",
          "created": 0
        },
        "s2Keys": {
          "description": "S2 Keys in hexadecimal",
          "type": "object",
          "properties": {
            "s0": {
              "$ref": "#/definitions/keyNonce"
            },
            "s2unauthenticated": {
              "$ref": "#/definitions/keyNonce"
            },
            "s2authenticated": {
              "$ref": "#/definitions/keyNonce"
            },
            "s2access": {
              "$ref": "#/definitions/keyNonce"
            }
          },
          "removed": 2
        },
        "s2KeysAssigned": {
          "description": "Assigned keys",
          "type": "integer",
          "removed": 2
        },
        "span": {
          "description": "SPAN",
          "type": "array",
          "item": {
            "type": "object",
            "properties": {
              "nonce": {
                "$ref": "#/definitions/keyNonce"
              },
              "lnode": {
                "type": "integer"
              },
              "rnode": {
                "type": "integer"
              },
              "rxSeq": {
                "description": "sequence number of last received message",
                "type": "integer"
              },
              "txSeq": {
                "description": "sequence number of last sent message",
                "type": "integer"
              },
              "classId": {
                "description": "The id of the security group in which this span is negotiated.",
                "type": "integer"
              },
              "state": {
                "type": "integer",
                "comment": [
                  "0: SPAN_NOT_USED",
                  "1: SPAN_NO_SEQ",
                  "2: SPAN_SOS",
                  "3: SPAN_SOS_LOCAL_NONCE",
                  "4: SPAN_SOS_REMOTE_NONCE",
                  "5: SPAN_INSTANTIATE",
                  "6: SPAN_NEGOTIATED"
                ]
              }
            }
          },
          "removed": 2
        },
        "mpan": {
          "description": "MPAN",
          "type": "array",
          "item": {
            "type": "object",
            "properties": {
              "ownerId": {
                "description": "this is the node id of the node maintaining mcast group members",
                "type": "integer"
              },
              "groupId": {
                "description": "a unique id generated by the group maintainer(sender)",
                "type": "integer"
              },
              "innerState": {
                "description": "The Multicast  pre-agreed nonce inner state",
                "$ref": "#/definitions/keyNonce"
              },
              "classId": {
                "type": "integer"
              },
              "state": {
                "type": "integer"
              }
            }
          },
          "removed": 2
        }
      },
      "required": [
        "protocolVersion",
        "applicationVersion",
        "applicationName",
        "homeId",
        "nodeId",
        "staticControllerNodeId",
        "lastNodeIdLR",
        "lastNodeId",
        "sucLastIndex",
        "maxNodeIdLR",
        "maxNodeId",
        "controllerIsSecondary",
        "controllerOnOtherNetwork",
        "controllerNodeIdServerPresent",
        "controllerIsRealPrimary",
        "controllerIsSuc",
        "noNodesIncluded",
        "reservedId",
        "reservedIdLR",
        "systemState",
        "primaryLongRangeChannelId",
        "longRangeChannelAutoMode",
        "isListening",
        "genericDeviceClass",
        "specificDeviceClass",
        "cmdClasses",
        "rfConfig",
        "applicationData",
        "dcdcConfig",
        "sucUpdateEntries"
      ]
    },
    "nodes": {
      "description": "generic data stored by the z-wave stack of the controller, zaf and the controller application.",
      "type": "object",
      "patternProperties": {
        "^[0-9]+$": {
          "description": "represent a Classic node in the network",
          "comment": [
            "there is one instance of this properties for each product in the network",
            "the property name is the nodeid of the product: '2', '3'...."
          ],
          "type": "object",
          "properties": {
            "isVirtual": {
              "description": "true if it's a virtual node",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "isListening": {
              "description": "true if the device is an always listening device.",
              "type": "boolean",
              "group": "stack",
              "default_value": true,
              "created": 0
            },
            "isFrequentListening": {
              "description": "true if the device is a flirs device.",
              "enum": [
                false,
                "250ms",
                "1000ms"
              ],
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "isRouting": {
              "description": "true if the device is capable of repeating frames.",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "supportedDataRates": {
              "description": "list of data rates supported by the product.",
              "comment": "9600 is implicitly always supported.",
              "type": "array",
              "items": {
                "enum": [
                  9600,
                  40000,
                  100000
                ]
              },
              "group": "stack",
              "default_value": [],
              "created": 0
            },
            "protocolVersion": {
              "description": "protocol version supported by the product.",
              "type": "integer",
              "group": "stack",
              "default_value": 1,
              "created": 0
            },
            "optionalFunctionality": {
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "nodeType": {
              "description": "node type",
              "type": "integer",
              "group": "stack",
              "default_value": 0,
              "created": 0
            },
            "supportsSecurity": {
              "description": "supports security",
              "type": "boolean",
              "group": "stack",
              "default_value": true,
              "created": 0
            },
            "supportsBeaming": {
              "description": "the device is able to send beam.",
              "type": "boolean",
              "group": "stack",
              "default_value": true,
              "created": 0
            },
            "genericDeviceClass": {
              "description": "generic device class",
              "type": "integer",
              "group": "stack",
              "default_value": 0,
              "created": 0
            },
            "specificDeviceClass": {
              "description": "specific device class",
              "$ref": "#/definitions/specificDeviceClassType",
              "group": "stack",
              "default_value": null,
              "created": 0
            },
            "neighbours": {
              "description": "list of device (nodeid) in direct range of this product.",
              "type": "array",
              "items": {
                "type": "integer"
              },
              "group": "stack",
              "created": 0,
              "default_value": []
            },
            "sucUpdateIndex": {
              "description": "suc update index.",
              "type": "integer",
              "group": "stack",
              "created": 0
            },
            "appRouteLock": {
              "description": "app route lock",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "routeSlaveSuc": {
              "description": "route slave suc",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "sucPendingUpdate": {
              "description": "suc pending update",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "pendingDiscovery": {
              "description": "pending discovery",
              "type": "boolean",
              "group": "stack",
              "default_value": false,
              "created": 0
            },
            "lwr": {
              "description": "last working route",
              "$ref": "#/definitions/routeProperties"
            },
            "nlwr": {
              "description": "next last working route",
              "$ref": "#/definitions/routeProperties"
            }
          },
          "required": [
            "isVirtual",
            "isListening",
            "isFrequentListening",
            "isRouting",
            "supportedDataRates",
            "protocolVersion",
            "optionalFunctionality",
            "nodeType",
            "supportsSecurity",
            "supportsBeaming",
            "genericDeviceClass",
            "neighbours",
            "sucUpdateIndex",
            "appRouteLock",
            "routeSlaveSuc",
            "sucPendingUpdate",
            "pendingDiscovery"
          ]
        }
      }
    },
    "lrNodes": {
      "description": "generic data stored by the z-wave stack of the controller, zaf and the controller application.",
      "type": "object",
      "patternProperties": {
        "^[0-9]+$": {
          "description": "represent a Long Range node in the network",
          "comment": [
